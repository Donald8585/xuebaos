{
  "name": "xuebaos-worker",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "wrangler dev",
    "build": "tsc --noEmit",
    "deploy": "wrangler deploy",
    "db:generate": "drizzle-kit generate",
    "db:migrate:local": "wrangler d1 execute xuebaos-db --local --file=./drizzle/migrations/*.sql",
    "db:migrate:prod": "wrangler d1 execute xuebaos-db --file=./drizzle/migrations/*.sql",
    "lint:check": "grep -rn \"schema\\[.*\\\"\" src/ && echo \"ERROR: bracket-access on schema detected! Use TABLES registry or direct import.\" && exit 1 || echo \"OK: no schema bracket access\"",
    "test": "npx tsx src/__tests__/middleware.test.ts && npx tsx src/__tests__/invariant.test.ts"
  },
  "dependencies": {
    "@clerk/backend": "^1.15.0",
    "@hono/zod-validator": "^0.8.0",
    "drizzle-kit": "^0.24.0",
    "drizzle-orm": "^0.33.0",
    "elevenlabs": "^1.50.0",
    "hono": "^4.5.0",
    "stripe": "^16.0.0",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20250501.0",
    "@typescript-eslint/eslint-plugin": "^7.18.0",
    "@typescript-eslint/parser": "^7.18.0",
    "eslint": "^8.57.1",
    "typescript": "^5.5.0",
    "wrangler": "^3.65.0"
  }
}