# XueBaOS — Environment Variables
# Copy to .env and fill in values. NEVER commit .env to git.

# ── Cloudflare ──────────────────────────────────────────────────
CLOUDFLARE_ACCOUNT_ID=
CLOUDFLARE_API_TOKEN=

# ── Clerk (Auth) ────────────────────────────────────────────────
CLERK_SECRET_KEY=
CLERK_WEBHOOK_SECRET=

# ── Stripe (Payments) ───────────────────────────────────────────
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# ── AI Providers ────────────────────────────────────────────────
# Primary: DeepSeek (cheaper, faster)
DEEPSEEK_API_KEY=
# Fallback: OpenAI (when DeepSeek is down)
OPENAI_API_KEY=

# Optional: Override default model selection
# LLM_PRIMARY_MODEL=deepseek-chat      # default
# LLM_FALLBACK_MODEL=gpt-4o-mini       # default

# ── Other AI ────────────────────────────────────────────────────
REPLICATE_API_TOKEN=
ELEVENLABS_API_KEY=

# ── Email (Resend) ──────────────────────────────────────────────
RESEND_API_KEY=
